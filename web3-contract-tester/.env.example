# Polygonscan API Key for fetching ABIs
# Get your free API key from https://polygonscan.com/
VITE_POLYGONSCAN_API_KEY=YourPolygonscanApiKeyHere

# Development mode private key (OPTIONAL - for local testing only)
# WARNING: Never commit real private keys to version control
VITE_DEV_PRIVATE_KEY=

# Development mode address (OPTIONAL - for local testing only)
VITE_DEV_ADDRESS=
