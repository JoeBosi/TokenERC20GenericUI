# ─────────────────────────────────────────────────────────────────────────
# SECRET HANDLING — read /docs/SECRETS.md before adding anything sensitive here.
#
# Anything prefixed VITE_ is COMPILED INTO THE PUBLIC BROWSER BUNDLE.
# It is NOT a secret. Use VITE_ vars only for local development convenience
# or for genuinely public values. Real secrets are configured server-side
# (no VITE_ prefix) — e.g. POLYGONSCAN_API_KEY in your Vercel project, which
# the /api/etherscan proxy reads. NEVER put a real private key in a VITE_ var.
# ─────────────────────────────────────────────────────────────────────────

# LOCAL DEV ONLY: lets `npm run dev` call Etherscan directly without the proxy.
# In production this is left UNSET, so the app uses the server-side proxy and
# the key (POLYGONSCAN_API_KEY, set in Vercel) never reaches the browser.
# Get a free key from https://etherscan.io/ (one key works across chains on V2).
VITE_POLYGONSCAN_API_KEY=YourPolygonscanApiKeyHere

# Development mode private key (OPTIONAL - LOCAL TESTING ONLY).
# WARNING: this WOULD be exposed in any production build. Only ever use a
# throwaway testnet key here, never a key holding real value.
VITE_DEV_PRIVATE_KEY=

# Development mode address (OPTIONAL - for local testing only)
VITE_DEV_ADDRESS=
